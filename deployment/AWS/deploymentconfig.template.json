{
  "django": {
    "image": ":perch-social.django.latest",
    "ports": { "8000": "HTTP" }
  },
  "nginx": {
    "image": ":perch-social.nginx.latest",
    "ports": { "80": "HTTP" }
  },
  "rq-worker": {
    "image": ":perch-social.rqworker.latest"
  },
  "rq-scheduler": {
    "image": ":perch-social.rqscheduler.latest",
    "environment": {
      "REDIS_HOST": "__REDIS_HOST__",
      "REDIS_USER": "__REDIS_USER__",
      "REDIS_PASSWORD": "__REDIS_PASSWORD__",
      "REDIS_PORT": "6379",
      "REDIS_URL": "__REDIS_URL__"
    }
  }
}